{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "An item available for purchase in the store",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "price": { "type": "number", "description": "Product price" },
        "category": { "type": "string", "description": "Product category" },
        "stock": { "type": "number", "description": "Available quantity" },
        "images": { "type": "array", "items": { "type": "string" }, "description": "List of image URLs" },
        "description": { "type": "string", "description": "Product description" },
        "ratings": { "type": "number", "description": "Average rating" },
        "reviews": { "type": "array", "items": { "$ref": "Review" }, "description": "Customer reviews" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer purchase",
      "type": "object",
      "properties": {
        "orderId": { "type": "string", "description": "Unique order identifier" },
        "userId": { "type": "string", "description": "ID of the user who placed the order" },
        "items": { "type": "array", "items": { "$ref": "OrderItem" } },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "processing", "delivered"] },
        "customerInfo": { "type": "object", "properties": {
          "name": { "type": "string" },
          "phone": { "type": "string" },
          "address": { "type": "string" }
        }},
        "paymentMethod": { "type": "string", "enum": ["cod", "bkash", "nagad"] },
        "paymentStatus": { "type": "string", "enum": ["pending", "paid"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "items", "total", "status", "customerInfo"]
    },
    "User": {
      "title": "User",
      "description": "Application user",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "wishlist": { "type": "array", "items": { "type": "string" } },
        "cart": { "type": "array", "items": { "$ref": "OrderItem" } }
      }
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discount code",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discount": { "type": "number" },
        "expiry": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "System notification",
      "type": "object",
      "properties": {
        "message": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "SiteSettings": {
      "title": "Site Settings",
      "description": "Global website configuration and links",
      "type": "object",
      "properties": {
        "siteName": { "type": "string", "description": "The name of the website" },
        "footerSupportLinks": { "type": "array", "items": { "type": "object", "properties": { "label": { "type": "string" }, "url": { "type": "string" } } } },
        "footerCompanyLinks": { "type": "array", "items": { "type": "object", "properties": { "label": { "type": "string" }, "url": { "type": "string" } } } },
        "socialLinks": { "type": "array", "items": { "type": "object", "properties": { "platform": { "type": "string" }, "url": { "type": "string" } } } },
        "siteDescription": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/products": { "schema": "Product", "description": "Store products" },
    "/orders": { "schema": "Order", "description": "Customer orders" },
    "/users": { "schema": "User", "description": "User profiles" },
    "/coupons": { "schema": "Coupon", "description": "Discount coupons" },
    "/notifications": { "schema": "Notification", "description": "Admin notifications" },
    "/settings": { "schema": "SiteSettings", "description": "Global website settings" }
  }
}
